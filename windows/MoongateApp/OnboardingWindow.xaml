<Window x:Class="Moongate.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L.Onboarding.Title}"
        Width="560" Height="500" MinWidth="520" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Border Padding="24">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button x:Name="BackButton"
                        Content="{DynamicResource L.Onboarding.Back}"
                        MinWidth="92"
                        Margin="0,0,8,0"
                        Click="OnBackClick"/>
                <Button x:Name="NextButton"
                        Content="{DynamicResource L.Onboarding.Next}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="92"
                        Click="OnNextClick"/>
                <Button x:Name="StartButton"
                        Content="{DynamicResource L.Onboarding.Start}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="104"
                        Visibility="Collapsed"
                        Click="OnStartClick"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="{DynamicResource L.Onboarding.Title}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBlock Text="{DynamicResource L.Onboarding.Subtitle}"
                           Style="{StaticResource Caption}"
                           FontSize="12.5"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14"/>

                <UniformGrid Columns="4" Margin="0,0,0,14">
                    <TextBlock x:Name="LanguageStepLabel"
                               Text="{DynamicResource L.Onboarding.LanguageStep}"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="SubtitleSourceStepLabel"
                               Text="{DynamicResource L.Onboarding.SubtitleSourceStep}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="TranslationMethodStepLabel"
                               Text="{DynamicResource L.Onboarding.TranslationMethodStep}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="ReadinessStepLabel"
                               Text="{DynamicResource L.Onboarding.ReadinessStep}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </UniformGrid>

                <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12" MinHeight="238">
                    <Grid>
                        <StackPanel x:Name="LanguagePanel">
                            <TextBlock Text="{DynamicResource L.Onboarding.LanguageStep}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,14"/>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource L.Onboarding.AppLanguage}"
                                           Width="132"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="AppLanguageBox" SelectedIndex="0">
                                    <ComboBoxItem Content="{DynamicResource L.Settings.LangAuto}"/>
                                    <ComboBoxItem Content="简体中文"/>
                                    <ComboBoxItem Content="繁體中文"/>
                                    <ComboBoxItem Content="English"/>
                                </ComboBox>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{DynamicResource L.Onboarding.TargetLanguage}"
                                           Width="132"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="TargetLanguageBox" SelectedIndex="0">
                                    <ComboBoxItem Content="简体中文"/>
                                    <ComboBoxItem Content="繁體中文"/>
                                    <ComboBoxItem Content="English"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>

                        <StackPanel x:Name="SubtitleSourcePanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource L.Onboarding.SubtitleSourceStep}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{DynamicResource L.Onboarding.PlatformSubtitlePreference}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>
                            <CheckBox x:Name="PreferLocalSpeechRecognitionBox"
                                      Content="{DynamicResource L.Onboarding.PreferLocalSpeechRecognition}"
                                      Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource L.Onboarding.LocalSpeechSetupLater}"
                                       Style="{StaticResource Caption}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel x:Name="TranslationMethodPanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource L.Onboarding.TranslationMethodStep}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource L.Onboarding.TranslationProvider}"
                                           Width="132"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="TranslationProviderBox" SelectedIndex="0">
                                    <ComboBoxItem Content="Anthropic"/>
                                    <ComboBoxItem Content="OpenAI-compatible"/>
                                </ComboBox>
                            </DockPanel>
                            <TextBlock Text="{DynamicResource L.Onboarding.AIOptional}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="{DynamicResource L.Onboarding.APILaterSummary}"
                                       Style="{StaticResource Caption}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel x:Name="ReadinessPanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource L.Onboarding.ReadinessSummary}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,14"/>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource L.Onboarding.AppLanguage}"
                                           Width="132"/>
                                <TextBlock x:Name="SummaryAppLanguage"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource L.Onboarding.TargetLanguage}"
                                           Width="132"/>
                                <TextBlock x:Name="SummaryTargetLanguage"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource L.Onboarding.TranslationMethodStep}"
                                           Width="132"/>
                                <TextBlock x:Name="SummaryTranslationMethod"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{DynamicResource L.Onboarding.SubtitleSourceStep}"
                                           Width="132"/>
                                <TextBlock x:Name="SummarySubtitleSource"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <TextBlock x:Name="ErrorText"
                           Foreground="{DynamicResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
