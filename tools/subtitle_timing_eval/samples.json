  "schema_version": 1,
  "notes": [
    "Artifacts generated from these samples belong under artifacts/subtitle_timing_eval/ and are not committed.",
    "source may be a stable YouTube URL or a yt-dlp ytsearch1: query when the exact fixture video should be selected at run time and recorded in the generated report.",
    "Scope is intentionally mainstream-language coverage, not every language on YouTube."
  ],
  "coverage_goal": {
    "id": "mainstream_language_timing_gate",
    "description": "Product-pragmatic target for mainstream languages/users Moongate is most likely to serve: en/zh/yue/ja/ko/es/fr/it plus translated subtitle timing. This keeps the 90% human-like gate bounded instead of tuning every long-tail language on YouTube.",
    "required_language_groups": ["en", "zh", "yue", "ja", "ko", "es", "fr", "it", "translated"]
  },
  "category_coverage_goal": {
    "id": "local_asr_content_type_coverage",
    "description": "The local-ASR timing-profile work (speech/lyrics/anime) must be validated on a spread of content types, not just talks. The real 10-sample eval should cover these categories; entries sourced via ytsearch1: resolve at run time and STILL require a human caption / human lyric reference to be authored before they pass the local-asr suite gate (metrics only count local-ASR output vs a human reference).",
    "required_categories": ["music_lyrics", "animation", "english_talk", "japanese_talk", "cantonese_chinese", "korean_talk", "french_talk", "italian_talk", "spanish_talk", "portuguese_talk"]
  },
